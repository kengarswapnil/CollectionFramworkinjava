// String in java 
class Main {
    public static void main(String[] args) {
        String s = "Swapnil kengar";
        s.concat("kengar");
        System.out.println(s); //not changed string
        
        System.out.println(s.length());
        System.out.println(s.charAt(1));
        System.out.println(s.equals("Swapnil"));
        System.out.println(s.equalsIgnoreCase("swapnil"));
        System.out.println(s.contains("Sw"));
        System.out.println(s.indexOf("s"));
        System.out.println(s.substring(1,2));
        System.out.println(s.replace("S","c"));
        System.out.println(s.toUpperCase());
        System.out.println(s.toLowerCase());
        System.out.println(s.trim());
        System.out.println(s.split(" "));
    }
    
}
